modules = ["nodejs-20", "web", "bash", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

  [[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "DB Migrate"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "All Services"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AJKMart App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "format"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Admin App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Rider App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Vendor App"

  [[workflows.workflow]]
name = "DB Migrate"
author = "agent"

  [workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd lib/db && DATABASE_URL=$(echo $DATABASE_URL | sed 's/-pooler//') node ../../node_modules/.bin/drizzle-kit push --force --config ./drizzle.config.ts"

  [[workflows.workflow]]
  name = "All Services"
  mode = "parallel"
  author = "agent"

  [[workflows.workflow.tasks]]
  task = "workflow.run"
  args = "API Server"

  [[workflows.workflow.tasks]]
  task = "workflow.run"
  args = "Rider App"

  [[workflows.workflow.tasks]]
  task = "workflow.run"
  args = "Vendor App"

  [[workflows.workflow.tasks]]
  task = "workflow.run"
  args = "Admin App"

  [[workflows.workflow.tasks]]
  task = "workflow.run"
  args = "AJKMart App"

  [[workflows.workflow]]
  name = "API Server"
  author = "agent"

  [workflows.workflow.metadata]
  outputType = "webview"

  [[workflows.workflow.tasks]]
  task = "shell.exec"
  args = "cd artifacts/api-server && NODE_ENV=development node ./scripts/start-with-restart.mjs"
  waitForPort = 5000

  [[workflows.workflow]]
name = "Rider App"
author = "agent"

  [workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/rider-app && PORT=3002 BASE_PATH=/rider node ../../node_modules/.bin/vite --config vite.config.ts --host 0.0.0.0 --strictPort"
waitForPort = 3002

  [[workflows.workflow]]
name = "Vendor App"
author = "agent"

  [workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/vendor-app && PORT=3001 BASE_PATH=/vendor node ../../node_modules/.bin/vite --config vite.config.ts --host 0.0.0.0 --strictPort"
waitForPort = 3001

  [[workflows.workflow]]
name = "Admin App"
author = "agent"

  [workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/admin && PORT=3000 BASE_PATH=/admin node ../../node_modules/.bin/vite --config vite.config.ts --host 0.0.0.0 --strictPort"
waitForPort = 3000

  [[workflows.workflow]]
name = "AJKMart App"
author = "agent"

  [workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/ajkmart && CI=1 EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_REPL_ID=$REPL_ID REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN node /home/runner/workspace/node_modules/.pnpm/expo@54.0.33_@babel+core@7.29.0_@expo+metro-runtime@6.1.2_expo-router@6.0.23_graphql@16_5e7ed7cfca0f09772c259d84404ce721/node_modules/expo/bin/cli start --localhost --port 8081"

[[workflows.workflow]]
name = "format"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm format:check"

[workflows.workflow.metadata]
isValidation = true

  [agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_gemini_ai_integrations:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000

[nix]
channel = "stable-25_05"

[userenv]


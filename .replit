modules = ["nodejs-20", "web", "bash", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

  [[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "All Services"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Rider App"

  [[workflows.workflow]]
  name = "All Services"
  mode = "parallel"
  author = "agent"

  [[workflows.workflow.tasks]]
  task = "workflow.run"
  args = "API Server"

  [[workflows.workflow.tasks]]
  task = "workflow.run"
  args = "Rider App"

  [[workflows.workflow.tasks]]
  task = "workflow.run"
  args = "Vendor App"

  [[workflows.workflow.tasks]]
  task = "workflow.run"
  args = "Admin App"

  [[workflows.workflow.tasks]]
  task = "workflow.run"
  args = "AJKMart App"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && PORT=8080 pnpm dev"
waitForPort = 8080

[[workflows.workflow]]
name = "Rider App"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/rider-app && PORT=5000 VITE_API_PROXY_TARGET=http://127.0.0.1:8080 pnpm dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

  [agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_gemini_ai_integrations:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000

[nix]
channel = "stable-25_05"
packages = ["ztools"]

[userenv]


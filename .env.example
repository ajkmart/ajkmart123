# =============================================================================
# AJKMart Super App — Environment Variables Template
# =============================================================================
# SETUP GUIDE:
#
#   REPLIT:
#     → All secrets go in Replit Secrets panel (left sidebar → Tools → Secrets)
#     → Non-secret vars go in Environment Variables panel
#     → Run button starts all 4 services automatically
#
#   LOCALHOST / CODESPACES / VPS:
#     1. cp .env.example .env
#     2. Fill in all values below
#     3. pnpm install
#     4. pnpm dev       ← starts all 4 services in parallel
#
#   GITHUB → NEW REPLIT IMPORT:
#     1. Import repo on replit.com
#     2. Set all "REQUIRED" secrets in Replit Secrets panel
#     3. Hit Run — zero agent intervention needed
# =============================================================================

# ── DATABASE (REQUIRED) ───────────────────────────────────────────────────────
# PostgreSQL connection string
# Get free DB from: https://neon.tech, https://supabase.com, https://railway.app
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# ── JWT / AUTH SECRETS (REQUIRED) ─────────────────────────────────────────────
# Generate each with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
JWT_ISSUER=ajkmart
ADMIN_ACCESS_TOKEN_SECRET=
ADMIN_REFRESH_TOKEN_SECRET=
ADMIN_CSRF_SECRET=
ENCRYPTION_MASTER_KEY=
ERROR_REPORT_HMAC_SECRET=

# ── ADMIN SEED — first admin account (REQUIRED) ───────────────────────────────
ADMIN_SEED_PASSWORD=Admin@123
ADMIN_SEED_USERNAME=superadmin
ADMIN_SEED_EMAIL=admin@ajkmart.com
ADMIN_SEED_NAME=Super Admin

# ── DEV FLAGS ─────────────────────────────────────────────────────────────────
NODE_ENV=development
# Set to "true" in development ONLY — exposes OTP codes in API responses
ALLOW_DEV_OTP=true

# ── PORTS (auto-detected, change only if conflicts) ───────────────────────────
# API Server  → http://localhost:5000
# Admin Panel → http://localhost:3000   (also via http://localhost:5000/admin)
# Vendor App  → http://localhost:3001   (also via http://localhost:5000/vendor)
# Rider App   → http://localhost:3002   (also via http://localhost:5000/rider)
VITE_API_PROXY_TARGET=http://127.0.0.1:5000

# ── WEB PUSH / VAPID ─────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:admin@ajkmart.app

# ── REDIS (OPTIONAL — rate limiting, sessions) ────────────────────────────────
# Get free Redis: https://upstash.com
# Format: redis://default:password@host:port
REDIS_URL=

# ── FILE STORAGE / S3 (OPTIONAL) ─────────────────────────────────────────────
# Use DigitalOcean Spaces, Cloudflare R2, AWS S3, or Backblaze B2
STORAGE_BUCKET_URL=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET_NAME=
STORAGE_REGION=us-east-1

# ── SMS OTP / Twilio (OPTIONAL) ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── EMAIL / SendGrid (OPTIONAL) ──────────────────────────────────────────────
SENDGRID_API_KEY=
SMTP_HOST=smtp.sendgrid.net

# ── FIREBASE — push notifications (OPTIONAL) ─────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── AI / Gemini (OPTIONAL) ───────────────────────────────────────────────────
# On Replit: automatically provided via Gemini integration
GEMINI_API_KEY=

# ── MAPS (OPTIONAL) ──────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── ERROR TRACKING / Sentry (OPTIONAL) ───────────────────────────────────────
SENTRY_DSN=
SENTRY_WEBHOOK_SECRET=

# ── PRODUCTION ONLY ──────────────────────────────────────────────────────────
# Set these when deploying to production
APP_BASE_URL=https://yourapp.replit.app
FRONTEND_URL=https://yourapp.replit.app
ADMIN_BASE_URL=https://yourapp.replit.app/admin
